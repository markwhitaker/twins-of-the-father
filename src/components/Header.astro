---
import laurenAndHannah from '../images/lauren-and-hannah.jpg';
import markAndSimon from '../images/mark-and-simon.jpg';
---
<header>
  <div class="banner">
    <div class="banner-inner">
      <a href="/" class="site-title">The Twins<br />of the Father</a>
      <div class="polaroids">
        <div class="polaroid polaroid-back">
          <img src={markAndSimon.src} alt="Mark and Simon as children" />
          <p>Mark &amp; Simon</p>
        </div>
        <div class="polaroid polaroid-front">
          <img src={laurenAndHannah.src} alt="Lauren and Hannah as children" />
          <p>Lauren &amp; Hannah</p>
        </div>
      </div>
    </div>
  </div>
  <div class="nav-bar text-stone-800">
    <div class="nav-inner">
      <nav aria-label="Site navigation" class="flex flex-row justify-between">
        <div class="flex flex-row items-center gap-2">
          <a href="/" aria-label="Home" class="hover:text-rose-800">
            Home
          </a>
          &middot;
          <a href="/why-the-blog" aria-label="Why the blog?" class="hover:text-rose-800">
            Why the blog?
          </a>
        </div>
        <div>
          <a href="/search/" aria-label="Search" class="hover:text-rose-800">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>
          </a>
        </div>
      </nav>
    </div>
  </div>
</header>

<style>
  .banner {
    background: linear-gradient(150deg, #cc6070 0%, #a84858 100%);
    overflow: visible;
  }

  .banner-inner {
    max-width: 42rem;
    margin: 0 auto;
    padding: 3rem 1rem 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 9rem;
    position: relative;
  }

  .site-title {
    font-family: "Solway";
    font-weight: 500;
    font-size: 2.5rem;
    color: white;
    text-decoration: none;
    line-height: 1.25;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.25);
  }

  .site-title:hover {
    color: rgba(255, 255, 255, 0.85);
  }

  .polaroids {
    position: relative;
    width: 14rem;
    height: 9rem;
    flex-shrink: 0;
  }

  .polaroid {
    position: absolute;
    background: #fff;
    padding: 7px 7px 15px;
    box-shadow: 2px 3px 10px rgba(0, 0, 0, 0.5);
    width: 7.5rem;
  }

  .polaroid img {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  .polaroid p {
    text-align: center;
    font-family: Schoolbell;
    font-size: 0.8rem;
    color: #222;
    margin: 8px 0 -5px;
    line-height: 1;
  }

  .polaroid-back {
    right: 0;
    bottom: 0;
    transform: rotate(4deg);
    z-index: 1;
  }

  .polaroid-front {
    right: 7.5rem;
    bottom: 0.5rem;
    transform: rotate(-5deg);
    z-index: 2;
  }

  .nav-bar {
    border-bottom: 1px solid #e7e5e4;
    margin-bottom: 2rem;
  }

  .nav-inner {
    max-width: 42rem;
    margin: 0 auto;
    padding: 0.6rem 1rem;
  }

  nav {
    display: flex;
    gap: 1rem;
  }

  nav a {
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.15s;
  }
</style>
