---
import laurenAndHannah from '../images/lauren-and-hannah.jpg';
import markAndSimon from '../images/mark-and-simon.jpg';
---
<header>
  <div class="banner">
    <div class="banner-inner">
      <a href="/" class="site-title">The Twins<br />of the Father</a>
      <div class="polaroids">
        <div class="polaroid polaroid-back">
          <img src={markAndSimon.src} alt="Mark and Simon as children" />
          <p>Mark &amp; Simon</p>
        </div>
        <div class="polaroid polaroid-front">
          <img src={laurenAndHannah.src} alt="Lauren and Hannah as children" />
          <p>Lauren &amp; Hannah</p>
        </div>
      </div>
    </div>
  </div>
  <div class="nav-bar">
    <div class="nav-inner">
      <nav aria-label="Site navigation">
        <a href="/search/" aria-label="Search">Search</a>
        <a href="/rss.xml" aria-label="RSS feed">RSS</a>
      </nav>
    </div>
  </div>
</header>

<style>
  .banner {
    background: linear-gradient(150deg, #cc6070 0%, #a84858 100%);
    overflow: visible;
  }

  .banner-inner {
    max-width: 42rem;
    margin: 0 auto;
    padding: 2rem 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 9rem;
    position: relative;
  }

  .site-title {
    font-size: 2.5rem;
    font-weight: 600;
    color: white;
    text-decoration: none;
    line-height: 1.25;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.25);
  }

  .site-title:hover {
    color: rgba(255, 255, 255, 0.85);
  }

  .polaroids {
    position: relative;
    width: 14rem;
    height: 9rem;
    flex-shrink: 0;
  }

  .polaroid {
    position: absolute;
    background: #fff;
    padding: 7px 7px 15px;
    box-shadow: 2px 3px 10px rgba(0, 0, 0, 0.5);
    width: 7.5rem;
  }

  .polaroid img {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  .polaroid p {
    text-align: center;
    font-family: cursive;
    font-size: 0.75rem;
    color: #222;
    margin: 5px 0 0;
    line-height: 1;
  }

  .polaroid-back {
    right: 0;
    bottom: 0;
    transform: rotate(4deg);
    z-index: 1;
  }

  .polaroid-front {
    right: 7.5rem;
    bottom: 0.5rem;
    transform: rotate(-5deg);
    z-index: 2;
  }

  .nav-bar {
    border-bottom: 1px solid #e7e5e4;
    margin-bottom: 2rem;
  }

  .nav-inner {
    max-width: 42rem;
    margin: 0 auto;
    padding: 0.6rem 1rem;
    display: flex;
    justify-content: flex-end;
  }

  nav {
    display: flex;
    gap: 1rem;
  }

  nav a {
    font-size: 0.875rem;
    color: #78716c;
    text-decoration: none;
    transition: color 0.15s;
  }

  nav a:hover {
    color: #b45309;
  }
</style>
