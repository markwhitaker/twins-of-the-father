---
import BaseLayout from './BaseLayout.astro';
import { tagSlug } from '../utils/tag-slug';

interface Props {
  title: string;
  date: Date;
  tags: string[];
  prevPost?: { title: string; slug: string };
  nextPost?: { title: string; slug: string };
}

const { title, date, tags, prevPost, nextPost } = Astro.props;

const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---
<BaseLayout title={`${title} — Twins of the Father`}>
  <article class="mt-8" data-pagefind-body>
    <header class="mb-8">
      <time datetime={date.toISOString()} class="text-sm text-stone-400" data-pagefind-ignore>{formattedDate}</time>
      <h1 class="mt-2 text-3xl font-bold text-stone-900 leading-snug">{title}</h1>
      {tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-x-3 gap-y-1" data-pagefind-ignore>
          {tags.map(tag => (
            <a
              href={`/tags/${tagSlug(tag)}/`}
              class="text-xs text-stone-400 hover:text-rose-600 transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>
    <div class="prose prose-stone max-w-none">
      <slot />
    </div>
    <footer class="mt-12 pt-6 border-t border-stone-200" data-pagefind-ignore>
      <nav class="grid grid-cols-3 gap-4 text-sm items-top">
        <div class="min-w-0">
          {prevPost && (
            <a href={`/${prevPost.slug}/`} class="text-stone-500 hover:text-rose-600 transition-colors">
              <span class="text-xs block">&larr; Previous</span>
              <span class="truncate block">{prevPost.title}</span>
            </a>
          )}
        </div>
        <div class="text-center">
          <a href="/" class="text-xs text-stone-500 hover:text-rose-600 transition-colors">
            &uarr; All posts
          </a>
        </div>
        <div class="text-right min-w-0">
          {nextPost && (
            <a href={`/${nextPost.slug}/`} class="text-stone-500 hover:text-rose-600 transition-colors">
              <span class="text-xs block text-right">Next &rarr;</span>
              <span class="truncate block">{nextPost.title}</span>
            </a>
          )}
        </div>
      </nav>
    </footer>
  </article>
</BaseLayout>
