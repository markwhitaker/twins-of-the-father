---
import BaseLayout from './BaseLayout.astro';
import { tagSlug } from '../utils/tag-slug';

interface Props {
  title: string;
  date: Date;
  tags: string[];
}

const { title, date, tags } = Astro.props;

const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---
<BaseLayout title={`${title} — Twins of the Father`}>
  <article class="mt-8">
    <header class="mb-8">
      <time datetime={date.toISOString()} class="text-sm text-stone-400">{formattedDate}</time>
      <h1 class="mt-2 text-3xl font-bold text-stone-900 leading-snug">{title}</h1>
      {tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-x-3 gap-y-1">
          {tags.map(tag => (
            <a
              href={`/tags/${tagSlug(tag)}/`}
              class="text-xs text-stone-400 hover:text-amber-700 transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>
    <div class="prose prose-stone max-w-none">
      <slot />
    </div>
    <footer class="mt-12 pt-6 border-t border-stone-200">
      <a href="/" class="text-sm text-stone-400 hover:text-amber-700 transition-colors">
        &larr; All posts
      </a>
    </footer>
  </article>
</BaseLayout>
